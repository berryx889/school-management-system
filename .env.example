# Postgres. For local dev this points at a local Postgres instance over its Unix
# socket (avoids the Postgres.app TCP-connection permission dialog on macOS).
# Swap for a Neon connection string in production — no code changes needed.
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@/sms_dev?host=/tmp&port=5433

# Auth
JWT_SECRET=change-this-in-production

# Paystack (leave blank in dev — payment features will show "not configured")
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Arkesel SMS (leave blank in dev — SMS sends are logged, not delivered)
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=SMS

PORT=4000
CLIENT_URL=http://localhost:5173
